# Frontend web — variáveis de ambiente (prefixo VITE_ obrigatório para expor ao client)
# Copie para apps/web/.env quando precisar sobrescrever.

# URL base da API. Vazio = usa o proxy do Vite (/api -> localhost:3000) em desenvolvimento.
# Em produção, defina a URL pública da API, ex.: https://api.suaacademia.com.br
VITE_API_URL=
