// Schema Prisma — Sistema de Academia
// Modelos iniciais alinhados aos módulos do CLAUDE.md. Evoluir por migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusAluno {
  ATIVO
  INATIVO
  SUSPENSO
}

enum StatusMensalidade {
  PENDENTE
  PAGA
  VENCIDA
  CANCELADA
}

enum TipoAcesso {
  ENTRADA
  SAIDA
}

// MOD-01 — Aluno
model Aluno {
  id           String        @id @default(uuid())
  nome         String
  email        String        @unique
  cpf          String        @unique
  telefone     String?
  status       StatusAluno   @default(ATIVO)
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt
  mensalidades Mensalidade[]
  acessos      Acesso[]

  @@map("alunos")
}

// MOD-03 — Plano
model Plano {
  id           String        @id @default(uuid())
  nome         String
  valorMensal  Decimal       @db.Decimal(10, 2)
  descricao    String?
  ativo        Boolean       @default(true)
  criadoEm     DateTime      @default(now())
  mensalidades Mensalidade[]

  @@map("planos")
}

// MOD-04 — Financeiro (mensalidade)
model Mensalidade {
  id          String            @id @default(uuid())
  aluno       Aluno             @relation(fields: [alunoId], references: [id])
  alunoId     String
  plano       Plano             @relation(fields: [planoId], references: [id])
  planoId     String
  competencia String // AAAA-MM
  valor       Decimal           @db.Decimal(10, 2)
  vencimento  DateTime
  status      StatusMensalidade @default(PENDENTE)
  pagoEm      DateTime?
  criadoEm    DateTime          @default(now())

  @@index([alunoId])
  @@index([status])
  @@map("mensalidades")
}

// MOD-08 — Acesso (catraca)
model Acesso {
  id        String     @id @default(uuid())
  aluno     Aluno      @relation(fields: [alunoId], references: [id])
  alunoId   String
  tipo      TipoAcesso
  registro  DateTime   @default(now())

  @@index([alunoId])
  @@map("acessos")
}
