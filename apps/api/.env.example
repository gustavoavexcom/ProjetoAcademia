# Backend do Sistema de Academia — variáveis de ambiente
# Copie para apps/api/.env e preencha. NUNCA commitar o .env real.

# Conexão PostgreSQL (Prisma)
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/academia?schema=public"

# Porta HTTP da API
PORT=3000

# Origem permitida para CORS (front em dev). Em produção, a URL pública do frontend.
CORS_ORIGIN=http://localhost:5173
